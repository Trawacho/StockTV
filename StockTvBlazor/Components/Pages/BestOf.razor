@page "/bestof"
@using StockTvBlazor.Components.Models
@rendermode InteractiveServer
@inject StockTvBlazor.Components.Services.SettingsService _settingsService
@inject NavigationManager _navigationManager
@inject StockTvBlazor.Components.Networking.NetMqPublisherService _publisherService
@inject StockTvBlazor.Components.Services.MatchService _matchService
@inject StockTvBlazor.Components.ViewModels.BestOfViewModel ViewModel
@inject IJSRuntime JS
@implements IDisposable

<div class="main-grid default bestof" @onkeydown="HandleGlobalKeyDown" tabindex="0" style="outline:none;" @ref="inputRef">
	<div class="scoreboard-shell" style="@ViewModel.GetShellGridStyle()">
		@if (TeamNamesAvailable)
		{
			<div class="teamname teamname-left" data-autofit data-autofit-min="8" data-autofit-vertical="true">@ViewModel.LeftTeamName</div>
		}

		<div class="scoreboard-center">
			<div class="training-row training-top-row header-text">@ViewModel.HeaderText</div>

			<div class="training-row training-middle-row training-mid-grid">
				<div class="training-cell left-point-sum" data-autofit data-autofit-min="12">@ViewModel.LeftPointsSum</div>
				<div class="training-cell left-match-points" data-autofit data-autofit-min="10">@ViewModel.LeftMatchPoints</div>
				<div class="training-cell seperator" data-autofit data-autofit-min="12">:</div>
				<div class="training-cell right-match-points" data-autofit data-autofit-min="10">@ViewModel.RightMatchPoints</div>
				<div class="training-cell right-point-sum" data-autofit data-autofit-min="12">@ViewModel.RightPointsSum</div>
			</div>

			<div class="training-row training-bottom-row training-bottom-grid">
				<div class="training-cell left-points" data-autofit data-autofit-min="10">@ViewModel.LeftPoints</div>
				<div class="training-cell input-value" data-autofit data-autofit-min="10">@ViewModel.InputValue</div>
				<div class="training-cell right-points" data-autofit data-autofit-min="10">@ViewModel.RightPoints</div>
			</div>
		</div>

		@if (TeamNamesAvailable)
		{
			<div class="teamname teamname-right" data-autofit data-autofit-min="8" data-autofit-vertical="true">@ViewModel.RightTeamName</div>
		}
	</div>
</div>


@code {
	private ElementReference inputRef;
	private StockTvBlazor.Components.Models.Settings _settings => _settingsService.CurrentSettings;

	private bool TeamNamesAvailable => ViewModel.TeamNamesAvailable;


	protected override void OnInitialized()
	{
		ViewModel.OnViewModelChanged += HandleUpdate;
	}

	public void Dispose()
	{
		ViewModel.OnViewModelChanged -= HandleUpdate;
		ViewModel.Dispose();
	}

	private async void HandleUpdate()
	{
		await InvokeAsync(() =>
			{
				StateHasChanged();
			});
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
			await inputRef.FocusAsync();
			
		if (TeamNamesAvailable)
			await JS.InvokeVoidAsync("stockTvAutoFit.observe", ".main-grid.bestof");

	}

	private async Task HandleGlobalKeyDown(KeyboardEventArgs e)
	{
		await ViewModel.ProcessKeyAsync(e.Key);
	}


}