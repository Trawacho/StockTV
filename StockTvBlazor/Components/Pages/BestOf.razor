@page "/bestof"
@using StockTvBlazor.Components.Models
@rendermode InteractiveServer
@inject StockTvBlazor.Components.Services.SettingsService _settingsService
@inject NavigationManager _navigationManager
@implements IDisposable

<div class="main-grid" @onkeydown="HandleGlobalKeyDown" tabindex="0" style="outline:none;" @ref="inputRef">

	<!-- Linke Spalte -->
	<div class="sidebar-left">Links</div>

	<!-- Mittlere Spalte mit 3 Zeilen -->
	<div class="center-column">
		<div class="header-text">@Model.HeaderText</div>

		<div class="row-2 sub-grid">
			<div class="left-point-sum">@Model.LeftPointsSum</div>
			<div class="seperator">:</div>
			<div class="right-point-sum">@Model.RightPointsSum</div>
		</div>

		<div class="row-3 sub-grid">
			<div class="left-points">@Model.LeftPoins</div>
			<div class="input-value">@Model.InputValue</div>
			<div class="right-points">@Model.RightPoints</div>
		</div>
	</div>

	<!-- Rechte Spalte -->
	<div class="sidebar-right">Rechts</div>

</div>

<style>
	html, body {
		margin: 0;
		padding: 0;
		overflow: hidden;
		background-color: @(System.Drawing.ColorTranslator.ToHtml(_settings.BackgroundColor));
	}

	/* Haupt-Layout: 3 Spalten */
	.main-grid {
		background-color: @(System.Drawing.ColorTranslator.ToHtml(_settings.BackgroundColor));
		display: grid;
		grid-template-columns: 3vw 1fr 3vw;
		position: fixed;
		inset: 0;
		height: 100vh;
		width: 100vw;
		/* gap: 10px; */
	}

	/* Mittlere Spalte: Unterteilung in 3 Zeilen */
	.center-column {
		display: grid;
		grid-template-rows: auto 1fr auto; /* Mitte füllt den Rest */
		height: 100vh;
		/* gap: 10px; */
	}

	/* Die Sub-Grids für Zeile 2 und 3: Jeweils 3 Spalten */
	.sub-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr; /* 3 gleich große Spalten */
		gap: 5px;
		align-items: center;
		text-align: center;
	}

	.sidebar-left, .sidebar-right {
		display: grid;
		place-items: center; /* Zentriert den Text exakt mittig */
		height: 100vh; /* Füllt die volle Bildschirmhöhe */
		width: 3vw; /* Füllt die volle Spaltenbreite */
		overflow: hidden; /* Verhindert Überlaufen */
		/* SCHRIFT-LOGIK */
		/* Da die Spalte 3vw breit ist, nehmen wir fast 3vw als Schriftgröße */
		font-size: 2.8vw;
		font-weight: 900; /* Extra fett für maximale Füllung */
		white-space: nowrap; /* Text darf NIEMALS umbrechen */
		text-transform: uppercase; /* Großbuchstaben wirken oft "blockiger" und füllender */
		line-height: 1; /* Kein zusätzlicher Zeilenabstand */
	}

	/* Optik zur Verdeutlichung */
	/* Linke Sidebar: Text von unten nach oben (90° gegen den Uhrzeigersinn) */
	.sidebar-left {
		grid-column: 1;
		grid-row: 1 / span 3;
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		/* Ergebnis: Text liest sich von unten nach oben */
	}

	/* Rechte Sidebar: Text von oben nach unten */
	.sidebar-right {
		grid-column: 3;
		grid-row: 1 / span 3;
		writing-mode: vertical-rl;
		/* Ergebnis: Text liest sich von oben nach unten */
	}

	.header-text {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColor));
		padding: 5px;
		text-align: center;
	}

	.left-point-sum {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColorLeftt));
	}

	.right-point-sum {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColorRight));
	}

	.seperator {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColor));
	}

	.left-points {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColorLeftt));
	}

	.right-points {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColorRight));
	}

	.input-value {
		color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColor));
	}

	.row-3 {
		align-self: end;
		padding-bottom: 5px;
	}

	.sub-grid div {
		padding: 5px;
	}

</style>

@code {
	private ElementReference inputRef;
	private StockTvBlazor.Components.Models.Settings _settings => _settingsService.CurrentSettings;
	public BestOfViewModel Model { get; set; } = default!;

	protected override void OnInitialized()
	{
		Model = new BestOfViewModel(_settingsService, _navigationManager);
		Model.OnViewModelChanged += StateHasChanged;
	}

	public void Dispose()
	{
		Model.OnViewModelChanged -= StateHasChanged;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await inputRef.FocusAsync();
		}
	}
	private void HandleGlobalKeyDown(KeyboardEventArgs e)
	{
		Model.ProcessKey(e.Key);
		StateHasChanged(); // Sicherstellen, dass die Punkte sofort umschalten
	}


}