@page "/"
@rendermode InteractiveServer
@using StockTvBlazor.Components.Pages
@inherits HomeBase

<PageTitle>StockTV</PageTitle>

<ErrorBoundary>
    <ChildContent>

        <div class="hero">
            <h1>StockTV</h1>
            <p>Die Anzeige für den Stocksport</p>
        </div>

        <div class="grid">
            @if (CardComponents.Count > currentCardIndex)
            {
                <DynamicComponent Type="CardComponents[currentCardIndex]" />
            }
            else
            {
                <p style="color:red">Card Fehler</p>
            }
        </div>

        <div class="cta">
            <p>Weiterleitung in <strong>@countdown Sekunden</strong>...</p>
            <div class="progress-bar">
                <div class="progress" style="width:@progress%"></div>
            </div>
        </div>

    </ChildContent>

    <ErrorContent Context="ex">
        <div style="color:red; padding:20px;">
            <h3>⚠ Fehler auf der Seite</h3>
            <p>@ex.Message</p>
            <pre>@ex.StackTrace</pre>
        </div>
    </ErrorContent>
</ErrorBoundary>