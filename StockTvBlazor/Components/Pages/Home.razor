@page "/"

<PageTitle>StockTV</PageTitle>

<div class="hero">
    <h1>StockTV</h1>
    <p>Die Anzeige für den Stocksport</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Zuschauer & Vereine</h3>
        <p>
            Alle Spielstände auf einen Blick – auf jeder Bahn und in Echtzeit.
        </p>
    </div>

    <div class="card">
        <h3>Mehr Spannung</h3>
        <p>
            Spieler sehen alle Begegnungen und behalten den Überblick im Turnier.
        </p>
    </div>

    <div class="card">
        <h3>Einfache Bedienung</h3>
        <p>
            Intuitiv für jedes Alter – sogar mit 82 problemlos nutzbar.
        </p>
    </div>

    <div class="card">
        <h3>Spielmodi</h3>
        <p>
            Training, Turnier, Best-Of und Zielschießen – individuell angepasst.
        </p>
    </div>
</div>

@* <div class="cta">
    <button class="btn-primary">Zur Anzeige</button>
</div> *@

<style>
    .hero {
        text-align: center;
        padding: 30px 10px;
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        border-radius: 8px;
    }

        .hero h1 {
            margin: 0;
            font-size: 28px;
        }

        .hero p {
            margin: 5px 0 0;
            font-size: 14px;
        }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .card {
        padding: 15px;
        background: #f5f5f5;
        border-radius: 8px;
        font-size: 14px;
    }

        .card h3 {
            margin-top: 0;
            font-size: 16px;
        }

    .cta {
        text-align: center;
        margin-top: 20px;
    }

    .btn-primary {
        padding: 10px 20px;
        font-size: 14px;
        border: none;
        border-radius: 6px;
        background-color: #ff9800;
        color: white;
        cursor: pointer;
    }

        .btn-primary:hover {
            background-color: #e68900;
        }
</style>