@page "/"
@rendermode InteractiveServer
@* @using BlazorAppTests.Components.Pages *@
@using StockTvBlazor.Components.Pages
@inherits HomeBase

<PageTitle>StockTV</PageTitle>

<div class="hero">
    <h1>StockTV</h1>
    <p>Die Anzeige für den Stocksport</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Zuschauer & Vereine</h3>
        <p>Alle Spielstände auf einen Blick – auf jeder Bahn und in Echtzeit.</p>
    </div>

    <div class="card">
        <h3>Mehr Spannung</h3>
        <p>Spieler sehen alle Begegnungen und behalten den Überblick im Turnier.</p>
    </div>

    <div class="card">
        <h3>Einfache Bedienung</h3>
        <p>Intuitiv für jedes Alter – sogar mit 82 problemlos nutzbar.</p>
    </div>

    <div class="card">
        <h3>Spielmodi</h3>
        <p>Training, Turnier, Best-Of und Zielschießen – individuell angepasst.</p>
    </div>
</div>

<div class="cta">
    <p>Weiterleitung in <strong>@countdown Sekunden</strong>...</p>
    <div class="progress-bar">
        <div class="progress" style="width:@progress%"></div>
    </div>
</div>