@page "/themes"
@rendermode InteractiveServer
@using StockTvBlazor.Settings

<PageTitle>Themes verwalten</PageTitle>

<div class="theme-page">
    <div class="theme-sidebar">
        <div class="sidebar-header">
            <h2>Themes</h2>
            <button class="btn-new" @onclick="CreateNewTheme">+ Neu</button>
        </div>

        <div class="theme-list">
            @foreach (var theme in SettingsService.CurrentSettings.UI.AllThemes)
            {
                var isActive = SettingsService.CurrentSettings.UI.ActiveTheme.Id == theme.Id;
                var previewColor = theme.GetColors(SettingsService.CurrentSettings.UI.CurrentRichtung).BackgroundColor;

                <div class="theme-item @(isActive ? "active" : "")"
                     @onclick="() => SelectTheme(theme)">
                    <span class="theme-dot" style="background:@previewColor; border:1px solid #888;"></span>
                    <span class="theme-name">@theme.Name</span>

                    @if (theme.IsBuiltIn)
                    {
                        <span class="badge">Standard</span>
                    }
                    else if (theme is CustomTheme customTheme && customTheme.BaseTheme.HasValue)
                    {
                        <span class="badge">@customTheme.BaseTheme.Value</span>
                    }

                    @if (!theme.IsBuiltIn)
                    {
                        <button class="btn-icon btn-delete" title="Löschen"
                                @onclick:stopPropagation="true"
                                @onclick="() => DeleteTheme(theme.Id)">🗑</button>
                    }
                </div>
            }
        </div>
    </div>

    <div class="theme-editor">
        @if (_editingTheme is not null)
        {
            <div class="editor-header">
                <h3>@(_isNew ? "Neues Theme" : "Theme bearbeiten")</h3>
            </div>

            <div class="editor-body">
                <div class="field">
                    <label>Name</label>
                    <input type="text" @bind="_editingTheme.Name" placeholder="Theme-Name" />
                </div>

                <div class="field">
                    <label>Basis-Theme (optional)</label>
                    <select value="@_baseThemeValue" @onchange="OnBaseThemeChanged">
                        <option value="-1">-- Keine Basis --</option>
                        <option value="0">Hell</option>
                        <option value="1">Dunkel</option>
                    </select>
                </div>

                <div class="field">
                    <label>Schriftart (optional)</label>
                    <select value="@_selectedFontFamily" @onchange="OnFontFamilyChanged">
                        <option value="">-- Standard --</option>
                        @foreach (var font in FontService.GetAvailableFonts())
                        {
                            <option value="@font">@font</option>
                        }
                    </select>
                </div>

                <div class="color-grid">
                    <ColorField Label="Hintergrund"     @bind-Value="_editingTheme.Colors.BackgroundColor" />
                    <ColorField Label="Vordergrund"     @bind-Value="_editingTheme.Colors.ForegroundColor" />
                    <ColorField Label="Links-Farbe"     @bind-Value="_editingTheme.Colors.ForegroundLeft" />
                    <ColorField Label="Rechts-Farbe"    @bind-Value="_editingTheme.Colors.ForegroundRight" />
                    <ColorField Label="ZielSumme Ges."  @bind-Value="_editingTheme.Colors.ZielSummeGesamt" />
                    <ColorField Label="ZielSumme Einz." @bind-Value="_editingTheme.Colors.ZielSummeEinzel" />
                </div>

                <div class="preview-section">
                    <h4>Vorschau</h4>
                    <ThemePreview />
                </div>

                <div class="editor-footer">
                    <button class="btn-cancel" @onclick="CancelEdit">Abbrechen</button>
                    <button class="btn-save" @onclick="SaveTheme">Speichern</button>
                </div>
            </div>
        }
        else if (_previewColors is not null)
        {
            <div class="editor-header">
                <h3>@_previewName <span class="badge">Standard</span></h3>
            </div>

            <div class="editor-body">
                <div class="color-grid readonly">
                    <div class="color-field-readonly">
                        <span class="field-label">Hintergrund</span>
                        <span class="color-swatch-lg" style="background:@_previewColors.BackgroundColor;"></span>
                        <span class="hex-value">@_previewColors.BackgroundColor</span>
                    </div>
                    <div class="color-field-readonly">
                        <span class="field-label">Vordergrund</span>
                        <span class="color-swatch-lg" style="background:@_previewColors.ForegroundColor;"></span>
                        <span class="hex-value">@_previewColors.ForegroundColor</span>
                    </div>
                    <div class="color-field-readonly">
                        <span class="field-label">Links-Farbe</span>
                        <span class="color-swatch-lg" style="background:@_previewColors.ForegroundLeft;"></span>
                        <span class="hex-value">@_previewColors.ForegroundLeft</span>
                    </div>
                    <div class="color-field-readonly">
                        <span class="field-label">Rechts-Farbe</span>
                        <span class="color-swatch-lg" style="background:@_previewColors.ForegroundRight;"></span>
                        <span class="hex-value">@_previewColors.ForegroundRight</span>
                    </div>
                    <div class="color-field-readonly">
                        <span class="field-label">ZielSumme Ges.</span>
                        <span class="color-swatch-lg" style="background:@_previewColors.ZielSummeGesamt;"></span>
                        <span class="hex-value">@_previewColors.ZielSummeGesamt</span>
                    </div>
                    <div class="color-field-readonly">
                        <span class="field-label">ZielSumme Einz.</span>
                        <span class="color-swatch-lg" style="background:@_previewColors.ZielSummeEinzel;"></span>
                        <span class="hex-value">@_previewColors.ZielSummeEinzel</span>
                    </div>
                </div>

                <div class="preview-section">
                    <h4>Vorschau</h4>
                    <ThemePreview />
                </div>
            </div>
        }
        else
        {
            <div class="editor-empty">
                <p>Wähle ein Theme aus oder erstelle ein neues.</p>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="toast-error">@_errorMessage</div>
}
