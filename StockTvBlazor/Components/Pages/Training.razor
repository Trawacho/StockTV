@page "/training"
@using StockTvBlazor.Components.Models
@using System.Diagnostics
@rendermode InteractiveServer
@inject StockTvBlazor.Components.Models.Settings Settings
@inject NavigationManager NavigationManager

<div class="main-grid" @onkeydown="HandleGlobalKeyDown" tabindex="0" style="outline:none;" @ref="inputRef">

	<div class="header-text">@Model.HeaderText</div>

	<div class="row-2 sub-grid">
		<div class="left-point-sum">@Model.LeftPointsSum</div>
		<div class="seperator">:</div>
		<div class="right-point-sum">@Model.RightPointsSum</div>
	</div>

	<div class="row-3 sub-grid">
		<div class="left-points">@Model.LeftPoins</div>
		<div class="input-value">@Model.InputValue</div>
		<div class="right-points">@Model.RightPoints</div>
	</div>

</div>

<style>
	html, body {
		margin: 0;
		padding: 0;
		overflow: hidden;
		background-color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.MainBackground));
	}

	/* Haupt-Layout: 3 Spalten */
	.main-grid {
		background-color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.MainBackground));
		display: grid;
		grid-template-rows: auto 1fr auto; /* Mitte füllt den Rest */
		position: fixed;
		inset: 0;
		height: 100vh;
		width: 100vw;
	}

	/* Die Sub-Grids für Zeile 2 und 3: Jeweils 3 Spalten */
	.sub-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr; /* 3 gleich große Spalten */
		gap: 5px;
		align-items: center;
		text-align: center;
	}

	.header-text {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.MainTextForeground));
		padding: 5px;
		text-align: center;
	}

	.left-point-sum {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.LeftForeground));
	}

	.right-point-sum {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.RightForeground));
	}

	.seperator {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.MainTextForeground));
	}

	.left-points {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.LeftForeground));
	}

	.right-points {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.RightForeground));
	}

	.input-value {
		color: @(System.Drawing.ColorTranslator.ToHtml(Settings.ColorScheme.MainTextForeground));
	}

	.row-3 {
		align-self: end;
		padding-bottom: 5px;
	}

	.sub-grid div {
		padding: 5px;
	}

</style>

@code {
	private ElementReference inputRef;

	public TrainingViewModel Model { get; set; } = default!;

	protected override void OnInitialized()
	{
		Model = new TrainingViewModel(Settings, NavigationManager);
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await inputRef.FocusAsync();
		}
	}
	private void HandleGlobalKeyDown(KeyboardEventArgs e)
	{
		Model.ProcessKey(e.Key);
		StateHasChanged(); // Sicherstellen, dass die Punkte sofort umschalten
	}
}