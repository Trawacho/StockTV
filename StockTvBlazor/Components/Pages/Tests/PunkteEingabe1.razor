<div class="punkte-eingabe">
    <input @ref="inputRef"
           value="@WertText"
           @oninput="OnInputChanged"
           @onkeydown="HandleKeyDown"
           placeholder="Wert eingeben..." />
</div>

@code {
    private ElementReference inputRef;

    [Parameter]
    public string Punkte1 { get; set; } = "";

    [Parameter]
    public string Punkte2 { get; set; } = "";

    [Parameter]
    public string WertText { get; set; } = "";

    [Parameter]
    public EventCallback<string> OnWertChanged { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        WertText = e.Value?.ToString() ?? "";
        await OnWertChanged.InvokeAsync(WertText);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        await OnKeyDown.InvokeAsync(e);
    }

    public async Task SetFocusAsync()
    {
        await inputRef.FocusAsync();
    }
}