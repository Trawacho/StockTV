@page "/settings"
@using StockTvBlazor.Components.Models
@using System.Diagnostics
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@inject StockTvBlazor.Components.Services.SettingsService _settingsService
@inject NavigationManager _navigationManager
@implements IDisposable

<div class="main-grid settings" @onkeydown="HandleGlobalKeyDown" @onkeydown:stopPropagation  tabindex="0" style="outline:none;" @ref="inputRef">

    <div class="header-text">Configuration</div>

    <div class="settings-list">
        <!-- Each row: icon | value | label -->
        <div class="setting-row">
            <div class="icon">@(Model.IsThemeActive ? "▶" : "")</div>
            <div class="value">@Model.ThemeValue</div>
            <div class="label">Theme</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(Model.IsRichtungActive ? "▶" : "")</div>
            <div class="value">@Model.RichtungValue</div>
            <div class="label">Richtung (links/rechts)</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(Model.IsModusActive ? "▶" : "")</div>
            <div class="value">@Model.ModusValue</div>
            <div class="label">Modus</div>
        </div>

         <div class="setting-row">
            <div class="icon">@(Model.IsBahnNummerActive ? "▶" : "")</div>
            <div class="value">@Model.BahnNummerValue</div>
            <div class="label">Bahnnr.</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(Model.IsMaxPunkteProKehreActive ? "▶" : "")</div>
            <div class="value">@Model.MaxPunkteProKehreValue</div>
            <div class="label">Max Punkte pro Kehre</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(Model.IsMaxKehrenProSpielActive ? "▶" : "")</div>
            <div class="value">@Model.MaxKehrenProSpielValue</div>
            <div class="label">Kehren pro Spiel</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(Model.IsSpielgruppeActive ? "▶" : "")</div>
            <div class="value">@Model.SpielgruppeValue</div>
            <div class="label">Spielgruppe</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(Model.IsNetworkingActive ? "▶" : "")</div>
            <div class="value">@Model.NetworkingValue</div>
            <div class="label">Netzwerk</div>
        </div>
    </div>

</div>


@code {
    private ElementReference inputRef;
    private StockTvBlazor.Components.Models.Settings _settings => _settingsService.CurrentSettings;
    public SettingsViewModel Model { get; set; } = default!;

    protected override void OnInitialized()
    {
        Model = new SettingsViewModel(_settingsService, _navigationManager);
        _settingsService.OnConfigurationChanged += StateHasChanged;
    }

    public void Dispose()
    {
        _settingsService.OnConfigurationChanged -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await inputRef.FocusAsync();
        }
    }
    public void HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        Model.ProcessKey(e.Key);
        StateHasChanged(); // Sicherstellen, dass die Punkte sofort umschalten
    }


}
