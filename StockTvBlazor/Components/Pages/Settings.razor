@page "/settings"
@using StockTvBlazor.Models
@using System.Diagnostics
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@inject StockTvBlazor.Services.SettingsService _settingsService
@inject NavigationManager _navigationManager
@inject StockTvBlazor.Components.ViewModels.SettingsViewModel ViewModel
@implements IDisposable

<div class="settings-main-grid" @onkeydown="HandleGlobalKeyDown" @onkeydown:stopPropagation  tabindex="0" style="outline:none;" @ref="inputRef">

    <div class="settings-list">
        <!-- Each row: icon | value | label -->
        <div class="setting-row">
            <div class="icon">@(ViewModel.IsThemeActive ? "▶" : "")</div>
            <div class="value">@ViewModel.ThemeValue</div>
            <div class="label">Theme</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(ViewModel.IsRichtungActive ? "▶" : "")</div>
            <div class="value">@ViewModel.RichtungValue</div>
            <div class="label">Richtung (links/rechts)</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(ViewModel.IsModusActive ? "▶" : "")</div>
            <div class="value">@ViewModel.ModusValue</div>
            <div class="label">Modus</div>
        </div>

         <div class="setting-row">
            <div class="icon">@(ViewModel.IsBahnNummerActive ? "▶" : "")</div>
            <div class="value">@ViewModel.BahnNummerValue</div>
            <div class="label">Bahnnr.</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(ViewModel.IsMaxPunkteProKehreActive ? "▶" : "")</div>
            <div class="value">@ViewModel.MaxPunkteProKehreValue</div>
            <div class="label">Max Punkte pro Kehre</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(ViewModel.IsMaxKehrenProSpielActive ? "▶" : "")</div>
            <div class="value">@ViewModel.MaxKehrenProSpielValue</div>
            <div class="label">Kehren pro Spiel</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(ViewModel.IsSpielgruppeActive ? "▶" : "")</div>
            <div class="value">@ViewModel.SpielgruppeValue</div>
            <div class="label">Spielgruppe</div>
        </div>

        <div class="setting-row">
            <div class="icon">@(ViewModel.IsNetworkingActive ? "▶" : "")</div>
            <div class="value">@ViewModel.NetworkingValue</div>
            <div class="label">Netzwerk</div>
        </div>
    </div>

</div>


@code {
    private ElementReference inputRef;
    private StockTvBlazor.Models.Settings _settings => _settingsService.CurrentSettings;
	private bool _disposed = false;

    protected override void OnInitialized()
    {
        _settingsService.OnSettingsChanged += StateHasChanged;
		_settingsService.OnNavigationRequested += HandleNavigationRequested;
    }

    public void Dispose()
    {
		_disposed = true;
        _settingsService.OnSettingsChanged -= StateHasChanged;
		_settingsService.OnNavigationRequested -= HandleNavigationRequested;
        ViewModel.Dispose();
    }
    private void HandleNavigationRequested(string url)
    {
		if (_disposed) return;

        InvokeAsync(() => _navigationManager.NavigateTo(url));
	}

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await inputRef.FocusAsync();
        }
    }
    public async Task HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        await ViewModel.ProcessKeyAsync(e.Key);
        StateHasChanged(); // Sicherstellen, dass die Punkte sofort umschalten
    }


}
