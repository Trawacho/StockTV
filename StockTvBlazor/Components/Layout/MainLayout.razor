@inherits LayoutComponentBase
@inject StockTvBlazor.Components.Models.Settings _settings

<style>
    :root {
        --bg-color: @(System.Drawing.ColorTranslator.ToHtml(_settings.BackgroundColor));
        --fg-color: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColor));
        --fg-left: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColorLeftt));
        --fg-right: @(System.Drawing.ColorTranslator.ToHtml(_settings.ForegroundColorRight));
    }
</style>

<div class="page">
        <main>
        <article>
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
